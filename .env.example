# App Configuration
VITE_APP_NAME=ArgoPOS
VITE_APP_NAME_COMMERCE=ArgoPOS Commerce
VITE_APP_URL=http://localhost:5173

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# UI Configuration
VITE_DEFAULT_PAGE_SIZE=10
VITE_MAX_FILE_SIZE=5242880

# External Services (Optional)
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx

# Currency and Locale
VITE_DEFAULT_CURRENCY=IDR
VITE_DEFAULT_LOCALE=id-ID

# Business Configuration
VITE_BUSINESS_NAME=ArgoPOS
VITE_BUSINESS_EMAIL=info@argopos.com
VITE_BUSINESS_PHONE=+62 812-3456-7890
# VITE_BUSINESS_ADDRESS=Jl. Example No. 123, Jakarta

# POS Configuration
VITE_TAX_RATE=0.11
VITE_SERVICE_CHARGE=0

# Cache Configuration
VITE_CACHE_EXPIRATION=3600000

# Security
VITE_ENABLE_CSP=false
VITE_SESSION_TIMEOUT=3600000